            "Klauzule": "={{ $json.data.clause }}",
            "Riziko": "={{ $json.data.risk_level }}",
            "Problémy": "={{ $json.data.identified_issues }}",
            "Doporučení": "={{ $json.data.recommendation }}",
            "Metadata": "={{ $json.data.includeMetadata }}"
          },
          "matchingColumns": [],
          "schema": [
            { "id": "Datum", "displayName": "Datum", "required": false, "defaultMatch": false, "display": true, "type": "string", "canBeUsedToMatch": true },
            { "id": "Klauzule", "displayName": "Klauzule", "required": false, "defaultMatch": false, "display": true, "type": "string", "canBeUsedToMatch": true },
            { "id": "Riziko", "displayName": "Riziko", "required": false, "defaultMatch": false, "display": true, "type": "string", "canBeUsedToMatch": true },
            { "id": "Problémy", "displayName": "Problémy", "required": false, "defaultMatch": false, "display": true, "type": "string", "canBeUsedToMatch": true },
            { "id": "Doporučení", "displayName": "Doporučení", "required": false, "defaultMatch": false, "display": true, "type": "string", "canBeUsedToMatch": true },
            { "id": "Metadata", "displayName": "Metadata", "required": false, "defaultMatch": false, "display": true, "type": "string", "canBeUsedToMatch": true }
          ]
        },
        "options": {}
      },
